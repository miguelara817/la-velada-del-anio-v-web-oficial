---
import { SPONSORS } from "../consts/sponsors";

const firstRow = SPONSORS.slice(0, 5);
const secondRow = SPONSORS.slice(5);
---

<section id="sponsors">
    <div class="grid grid-cols-5 gap-4">
        {
            firstRow.map(({url, image, name}) => (
                <a 
                    href={url}
                    target="_blank"
                    class="size-10 hover:scale-125 transition"
                >
                    <image.logo class="h-8 w-auto"/>
                </a>
            ))
        }
    </div>
        <div class="grid grid-cols-6 gap-4">
        {
            secondRow.map(({url, image, name}) => (
                <a 
                    href={url}
                    target="_blank"
                    class="size-10 hover:scale-125 transition"
                >
                    <image.logo class="h-8 w-auto"/>
                </a>
            ))
        }
    </div>
</section>